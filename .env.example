# Copy to .env (or set in your host's dashboard) and fill in.

# --- Database (PostgreSQL) ---
# Leave unset to use the local docker-compose Postgres that run_local.sh starts:
#   postgresql+psycopg2://finpulse:finpulse@localhost:5432/finpulse
# For production point this at your managed Postgres / Supabase instance, e.g.:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# --- Ingestion tuning ---
# FINPULSE_HISTORY_PERIOD=1y     # how much history to pull (1mo,3mo,6mo,1y,max)
# FINPULSE_INGEST_DELAY=0.4      # seconds between yfinance calls (avoid throttling)

# --- Dashboard -> API wiring ---
# URL the Streamlit dashboard calls. Point this at your deployed API.
# FINPULSE_API_URL=http://127.0.0.1:8000
